                <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<script>

  document.addEventListener("DOMContentLoaded", () => {
    console.log("hlo")
    const logoutForm = document.getElementById("logoutForm2");
    if (logoutForm) {
      logoutForm.addEventListener("submit", async function (e) {
        e.preventDefault();
        if(confirm("Are your  sure you want to logout?")){
        let res = await fetch(window.location.origin+"/auth/logout", {
          method: "POST",
          credentials: "include"
        });
        

        if (res.ok) {
             Toastify({
                text: "Logged out SuccessFully!",
                duration: 3000,
                gravity: "top",
                position: "center",
                close: true,
                backgroundColor: "#AA8453",
                style: {
                    color: "#FFFFFF"
                }})
          window.location.href = "/login";
        }else{
            Toastify({
                text: "Something Went Wrong!",
                duration: 3000,
                gravity: "top",
                position: "center",
                close: true,
                backgroundColor: "#AA8453",
                style: {
                    color: "#FFFFFF"
                }})
        }
    }

      });
    }
  });


</script>