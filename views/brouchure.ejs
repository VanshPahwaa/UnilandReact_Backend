<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Property Details PDF</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #fff;
            color: #333;
            line-height: 1.5;
        }

        /* Header */
        .property-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .property-header h1 {
            font-size: 32px;
            font-weight: 700;
        }
        .property-header p {
            font-size: 14px;
            color: #555;
        }
        .property-price {
            font-size: 22px;
            color: #007bff;
            font-weight: 600;
            margin-top: 10px;
        }

        /* Main Image */
        .property-image {
            width: 100%;
            max-height: 450px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #ddd;
            margin-bottom: 30px;
        }

        /* Sections */
        h2 {
            font-size: 20px;
            border-bottom: 2px solid #ddd;
            padding-bottom: 5px;
            margin-top: 30px;
            margin-bottom: 15px;
        }
        .section-content li {
            padding: 5px 0;
        }
        .section-content li span {
            font-weight: 600;
            width: 150px;
            display: inline-block;
        }

        /* Amenities */
        .amenities li::before {
            content: "• ";
            color: #007bff;
            font-weight: bold;
        }

        /* Floor plan */
        .floor-plan img {
            width: 100%;
            border-radius: 6px;
            border: 1px solid #ccc;
            margin-top: 10px;
        }

        /* Table */
        table th, table td {
            border: 1px solid #ccc !important;
            padding: 0.5rem !important;
        }
        table th {
            background-color: #f5f5f5 !important;
        }

        /* Footer */
        .footer {
            text-align: center;
            font-size: 12px;
            color: #777;
            margin-top: 40px;
        }

        @media print {
            .property-image, .floor-plan img {
                page-break-inside: avoid;
            }
            .section {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>
    <div>
<div class="container my-4">
<a class="navbar-brand" href="/"><img class="nav-logo" src="/assets/images/logo/logo.png" alt="real estate template" style="width:175px;height:45px;"></a>


    <!-- Main Property Image -->
    <div class="text-center">
        <img src="<%=data.property.imageBase64%>" alt="Property Image" class="property-image mt-1">
    </div>

        <!-- Property Header -->
    <div class="property-header d-md-flex flex-row justify-content-between align-items-center">
        <div class="" style="text-align: start;">
            <h1><%=data.property.title%></h1>
            <p><%=data.property.address.unit%>, <%=data.property.address.street%>, <%=data.property.address.city%>, <%=data.property.address.district%>, <%=data.property.address.state%>, <%=data.property.address.pincode%></p>
        </div>
        <div class="property-price ">
            <% if (data.property.priceFrom){%>
                <%=data.property.priceFrom%>-<%=data.property.priceTo%> / All Inclusive
            <% } else if (data.property.rent) {%>
                <%=data.property.rent%> / Monthly
            <% } %>
        </div>
    </div>
    <!-- Overview -->
   <div class="section">
  <h2 class="fs-4">Overview</h2>
  <div class="grid">
    <div class="row lh-lg">
      <div class="col-4"><span class="fw-semibold">Apartment:</span> <%= data.property.additionalInformation.rooms %></div>
      <div class="col-4"><span class="fw-semibold">Area:</span> <%= data.property.area %> sqft</div>
      <div class="col-4"><span class="fw-semibold">Baths:</span> <%= data.property.additionalInformation.bathrooms %></div>
      <div class="col-4"><span class="fw-semibold">Year of Construction:</span> <%= data.property.yearOfConstruction %></div>
      <div class="col-4"><span class="fw-semibold">Property Type:</span> <%= data.property.propertyType %></div>
      <div class="col-4"><span class="fw-semibold">Property Stage:</span> <%= data.property.propertyStage %></div>
    </div>
  </div>
</div>


    <!-- Address -->
    <div class="section">
        <h2 class="fs-4">Address</h2>
        <div class="grid">
            <div class="row lh-lg">
                <div class="col">
                    <span style="font-weight: 600;">House/Unit No.:</span> <%=data.property.address.unit%>
                </div>
                <div class="col-3"><span class="" style="font-weight: 600;">House/Unit No.:</span> <%=data.property.address.unit%></div>
                <div class="col-3"><span   style="font-weight: 600;">Street:</span> <%=data.property.address.street%></div>
                <div class="col-3"><span  style="font-weight: 600;">City:</span> <%=data.property.address.city%></div>
                <div class="col-3"><span  style="font-weight: 600;">State:</span> <%=data.property.address.state%></div>
                <div class="col-3"><span  style="font-weight: 600;">Postal Code:</span> <%=data.property.address.pincode%></div>
                <div class="col-3"><span  style="font-weight: 600;">Postal Code:</span> <%=data.property.address.pincode%></div>
                <div class="col-3"><span  style="font-weight: 600;">Country:</span> India</div>
            </div>
        </div>
    </div>

    <!-- Amenities -->
 <div class="section">
  <h2 class="fs-4">Property Features / Amenities</h2>
  <div class="grid">
    <div class="row lh-lg">
      <% data.property.amenities.forEach((amenity) => { %>
        <div class="col-3 d-flex align-items-center">
<svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M379.33-244 154-469.33 201.67-517l177.66 177.67 378.34-378.34L805.33-670l-426 426Z"/></svg>
          <span><%= amenity.name %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>


    <!-- Floor Plans -->
    <!-- <div class="section">
        <h2>Floor Plans</h2>
        <div class="row">
            <div class="col-md-12 floor-plan">
                <h5>Floor Plan [4200 sqft]</h5>
                <ul>
                    <li>Bed: 162.5 sqft</li>
                    <li>Kitchen: 108.2 sqft</li>
                    <li>Dining: 145.7 sqft</li>
                    <li>Bath: 38.7 sqft</li>
                    <li>Storage: 123.2 sqft</li>
                </ul>
                <img src="assets/images/house-floor-plan.png" alt="Floor Plan">
            </div>
        </div>
    </div> -->

    <!-- Nearby Places -->
    <div class="section">
        <h2>Nearby Places</h2>
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Distance</th>
                    </tr>
                </thead>
                <tbody>
                    <%for (let key in data.property.additionalInformation.nearByPlace){%>
                        <tr>
                            <td><%=data.property.additionalInformation.nearByPlace[key].placeName%></td>
                            <td><%=data.property.additionalInformation.nearByPlace[key].distance%></td>
                        </tr>
                    <%}%>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Video Thumbnail -->
     <% if(data.property.vidio){%>
        <div class="section text-center">
        <h2>Video Presentation</h2>
        <img src="assets/images/background/bg-7.png" alt="Video Thumbnail">
    </div>
    <%}%>

    <!-- Footer -->
    <div class="footer">
        Property details provided by UniLand | Generated on <%= new Date().toLocaleDateString() %>
    </div>
</div>
</div>
</body>
</html>
