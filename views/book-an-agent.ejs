    <style>

        
    .letter-form {
     
      margin: 40px auto;
      padding: 20px;
    }

    .letter-form label {
      font-size: 14px;
      color: #555;
      margin-bottom: 2px;
      display: block;
    }

    /* Underline-only input style */
    .letter-form .form-control {
      border: none;
      border-bottom: 1px solid #aaa;
      border-radius: 0;
      background: transparent;
      font-size: 16px;
      color: #333;
      padding-left: 0;
    }

    .letter-form .form-control:focus {
      box-shadow: none;
      border-bottom: 1px solid #333;
      background: transparent;
    }


    textarea.form-control {
      resize: none;
    }

    /* Dropdown (location) styled same as inputs */
    .letter-form select.form-control {
      appearance: none;
       font-size: 14px;
      color: #555;
      
      -webkit-appearance: none;
      -moz-appearance: none;
    }

   select:focus {
  border-color: #007bff;
  outline: none;
}

select{
width: 100%;

}

select option{
  white-space: nowrap;
  overflow: hidden;
  width: 100%;
  text-overflow: ellipsis;
}


 </style>

</head>
<body class="contact-page">

    <div class="preloader">
        <div class="loader"></div>
    </div>

    <div id="page_wrapper" class="bg-light-gray">
        <!--============== Header Section Start ==============-->
        <%- include("partials/navbar.ejs")%>
            <%- include("partials/lead-model.ejs")%>

        <!--================== Header Section End =================-->

        <!--============== Page Banner Section Start ==============-->
        <div class="full-row p-3 p-md-5">
            <div class="container">
                <div class="row">
                    <div class="col">
                        <div class="page-title-wrapper d-lg-flex flex-column gap-1">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb bg-transparent p-0">
                                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Book An Agent</li>
                                </ol>
                            </nav>
                            <!-- <h1 class="page-title">Sell</h1> -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--=============== Page Banner Section End ===============-->

        <!--================== Page Content Start =================-->
  <div class="full-row pt-0">
  <div class="container bg-white p-2 p-md-4 rounded-5"> 
    <form id="paymentForm" class="letter-form">
      <div class="row g-5">
        <!-- Left side: User info -->
        <div class="col-12 col-md-6">
          <div class="w-100 align-items-center justify-content-center d-flex">
            <span><img src="/assets/images/agentLogo.png" height="200px" alt=""/></span>
          </div>

          <div class="row g-3">
            <div class="col-lg-12">
              <label>Username</label>
              <input type="text" name="clientName" class="form-control" placeholder="Username" required>
            </div>

            <div class="col-lg-12">
              <label>Email</label>
              <input type="email" name="email" class="form-control" placeholder="Email" required>
            </div>

            <div class="col-lg-12">
              <label>Location</label>
              <select class="form-control form-select p-1 " name="locationName" required>
                <option value="" disabled selected hidden>Select location</option>
                <% data.location.forEach((location, index) => { %>
                  <option class="form-select" style="color:#333; padding: 20px!important; border-radius: 10px;"  value="<%= location._id %>" >
                    <%= location.locationName %>
                  </option>
                <% }) %>
              </select>
            </div>
           
             <div class="col-lg-6">
              <label>Preferred Date</label>
              <input 
  type="date" 
  name="preferredDate" 
  class="form-control" 
  required 
  min="<%= new Date().toISOString().split('T')[0] %>" style="color: gray;">

            </div>

            <%if(data.time){%>  
             <div class="col-lg-6">
              <label>Time</label>
               <select class="form-control form-select p-1" name="preferredTime" required>
                <option value="" disabled selected hidden>Select location</option>
                <% data.time.forEach((time, index) => { %>
                  <option class="form-select" style="color:#333; padding: 20px!important; border-radius: 10px;"  value="<%= time %>" >
                  <%= time %>  
                  </option>
                <% }) %>
              </select>
            </div>
            <%}%>


            <input type="hidden" value="<%=data.amount%>" name="amount">

            <div class="col-lg-12">
              <label>Mobile Number</label>
              <input type="text" class="form-control" name="mobileNumber" placeholder="Mobile Number"
                     pattern="\d{10,}" maxlength="10" inputmode="numeric" required
                     oninvalid="this.setCustomValidity('Please enter a valid 10-digit mobile number')" 
                     oninput="this.setCustomValidity('')">
            </div>
            <div class="col-lg-12">
              <label>Message</label>
              <textarea name="message" class="form-control" placeholder="Message" rows="3"></textarea>
            </div>
            <input type="hidden" name="propertyInterested" id="propertyInterested" value="">
       </div>
        </div>

        <!-- Right side: Payment Gateways -->
        <div class="col-12 col-md-6 p-3 d-flex flex-column justify-content-space-evenly">
          <h2 class="text-center">Payment Gateways</h2>
          <div class="mt-3" style="height: 60%;">
            <div class="container py-5">
              <h4 class="mb-4 fw-semibold colour-secondary">Choose Payment Gateway</h4>
              <div class="list-group">

                <label class="list-group-item d-flex align-items-center gap-3 py-3">
                  <input class="form-check-input me-2" type="radio" name="paymentGateway" value="stripe">
                  <i class="fa-brands fa-stripe fs-3 text-primary"></i>
                  <span class="fw-medium fs-5">Stripe</span>
                </label>

                <label class="list-group-item d-flex align-items-center gap-3 py-3 px-0">
                  <div class="d-flex flex-column w-100">
                    <div class="ps-4 gap-3">
                      <input class="form-check-input me-2" type="radio" name="paymentGateway" value="paypal">
                      <i class="fa-brands fa-paypal fs-3 text-info me-4"></i>
                      <span class="fw-medium fs-5">PayPal</span>
                    </div>
                    <div id="paypal-button-container" class=""></div>
                  </div>
                </label>

                <label class="list-group-item d-flex align-items-center gap-3 py-3">
                  <input class="form-check-input me-2" type="radio" name="paymentGateway" value="razorpay">
