</head>

<body class="dashboard-message">

    <div class="preloader">
        <div class="loader"></div>
    </div>

    <div id="page_wrapper" class="bg-light-gray">
        <div class="sidebar-page-wrapper">
            <%- include("../partials/dashboard-navbar")%>

                <div class="right-sidebar-block">
                    <!--============== Dashboard Start ==============-->
<%- include("../partials/headerDashboard.ejs")%>

             <div class=" container">
                    <div class="row">
                        <div class="col">
                            <div class="page-title-wrapper d-lg-flex flex-column gap-3">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb mb-0 bg-transparent p-0">
                                        <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                                        <li class="breadcrumb-item"><a href="/admin/banks">Banks</a></li>

                    <li class="breadcrumb-item active" aria-current="page">New Banks</li>
                                    </ol>
                                </nav>
                              
                            </div>
                        </div>
                    </div>
                </div>


                    <div class="full-row p-3">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-12 d-flex flex-row justify-content-between">
                                    <h3 class="py-3 color-dark d-inline-block">New Bank</h3>  
                                </div>
                            </div>
                            <div class="row ">
                                <div class="col-12">
                                    <form class="submit-bank"  id="myForm">
                                        <div class="row g-3 px-2">
                                            <div class="col-md-12">
                                                <label class="mb-1">Bank Name</label>
                                                <input class="form-control" name="bankName" type="text" required
                                                    placeholder="Name">
                                            </div>
                                             <div class="col-md-12">
                                                <label class="mb-1">Rate of Interest</label>
                                                <input class="form-control" name="rateOfInterest" type="number" step="any" required
                                                    placeholder="Rate of Interest">
                                            </div>
                                           <div class="input-group mb-3">
    <input type="file" class="form-control" id="inputGroupFile02" style="height: 20px;" name="bankLogo">
    <label class="input-group-text" for="inputGroupFile02" style="height: 45px;">Upload</label>
</div>

                                            <button type="submit" class="btn btn-primary mt-4">Upload</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!--============== End Dashboard Start ==============-->

                    <!--============== Footer Start =============-->
                    <%- include("../partials/copyright.ejs")%>
                        <!--============== Footer End =============-->
                </div>
        </div>
    </div>

    <!-- Javascript Files -->
    <script src="assets/js/jquery.min.js"></script>
    <script src="assets/js/bootstrap.min.js"></script>
    <script src="assets/js/bootstrap-select.min.js"></script>
    <script src="assets/js/piechart/chart.min.js"></script>
    <script src="assets/js/owl.carousel.min.js"></script>
    <script src="assets/js/wow.min.js"></script>
    <script src="assets/js/mixitup.min.js"></script>
    <script src="assets/js/range/tmpl.js"></script>
    <script src="assets/js/range/jquery.dependClass.js"></script>
    <script src="assets/js/range/draggable.js"></script>
    <script src="assets/js/range/jquery.slider.js"></script>
    <script src="assets/js/paraxify.js"></script>
    <script src="assets/js/custom.js"></script>
    <!-- for toastify -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <script>


       const myForm = document.getElementById("myForm");

myForm.addEventListener("submit", async function (e) {
    try {
        console.log("Hllo")
        e.preventDefault();
        const formData = new FormData(this); // includes text + file inputs

        const res = await fetch(window.location.origin +"/backend/admin/bank/", {
            method: "POST",
            body: formData  // ✅ send directly
        });

        const data = await res.json();
        console.log(data);

        if (data.success) {
            Toastify({
                text: data.message || "Success: Uploaded Successfully",
                duration: 3000,
                gravity: "top",
                position: "center",
                close: true,
                backgroundColor: "#AA8453",
                style: {
                    color: "#FFFFFF"
                }
            }).showToast();
            this.reset();
        } else {
            throw new Error(data.error);
        }
    } catch (error) {
        Toastify({
            text: error.message,
            duration: 3000,
            gravity: "top",
            position: "center",
            close: true,
            backgroundColor: "#AA8453",
            style: {
                color: "#FFFFFF"
            }
        }).showToast();
    }
});



    </script>
</body>

</html>