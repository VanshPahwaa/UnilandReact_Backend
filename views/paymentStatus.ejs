<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Details</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      background-color: #f1f3f6;
    }
    .card {
      border-radius: 15px;
    }
    .check-icon {
      font-size: 3rem;
      color: #0d9d78;
      background: #e5f7f2;
      border-radius: 50%;
      padding: 15px;
      display: inline-block;
    }
    .details-table td {
      padding: 10px 0;
    }
  </style>
</head>
<body>
  <div class="container py-5">
    <%if(data && data.transactionDetail){%>
      
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow p-4">
          <div class="text-center">
            <span class="check-icon">
              <i class="bi bi-check-lg"></i>
            </span>
            <h5 class="mt-3 text-success fw-bold">Payment <%=data.transactionDetail.status.charAt(0).toUpperCase() + data.transactionDetail.status.slice(1).toLowerCase()%></h5>
            <p class="text-muted"></p>
          </div>

          <h6 class="fw-bold mt-4">DETAILS</h6>
          <table class="table table-borderless details-table">
            <tbody>
              <tr>
                <td class="fw-semibold">Payment ID</td>
                <td class="text-end"><%=data.transactionDetail.transactionId%></td>
              </tr>
              <tr>
                <td class="fw-semibold">User Name</td>
                <td class="text-end"><%=data.transactionDetail.clientName%></td>
              </tr>
              <tr>
                <td class="fw-semibold">Date</td>
                <td class="text-end"><%=new Date(data.transactionDetail.updatedAt).toLocaleString("en-IN",{
                  dateStyle:"medium",
                  timeStyle:"short"
                })%></td>
              </tr>
              <tr>
                <td class="fw-semibold">Payment Gateway</td>
                <td class="text-end"><%=data.transactionDetail.paymentGateway%></td>
              </tr>
              <tr>
                <td class="fw-semibold">Total Amount</td>
                <td class="text-end fw-bold">₹1000</td>
              </tr>
            </tbody>
          </table>

          <div class="d-grid mt-3">
            <a href="/" class="btn btn-success btn-lg">Done</a>
          </div>
        </div>
      </div>
    </div>
    <%}else{%>
      <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow p-4">
          No Detail Found 
          <div class="d-grid mt-3">
            <a href="/book-an-agent" class="btn btn-success btn-lg">Retry</a>
          </div>
        </div>
      </div>
    </div>
      <%}%>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
