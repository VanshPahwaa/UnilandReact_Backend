<!doctype html>
<html lang="en">

<head>
    <!-- Meta Tag -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Uniland - Real Estate HTML5 Template">
    <meta name="keywords"
        content="real estate, property, property search, agent, apartments, booking, business, idx, housing, real estate agency, rental">
    <meta name="author" content="unicoder">
    <title>Uniland - Real Estate HTML5 Template</title>
    <!-- Favicon -->
    <link rel="shortcut icon" href="assets/images/favicon2.ico">

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap"
        rel="stylesheet">

    <!--  CSS Style -->
    <link rel="stylesheet" href="assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="assets/css/all.min.css">
    <link rel="stylesheet" href="assets/css/animate.min.css">
    <link rel="stylesheet" href="assets/css/fancybox.min.css">
    <link rel="stylesheet" href="assets/css/layerslider.css">
    <link rel="stylesheet" href="assets/css/owl.carousel.min.css">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="stylesheet" href="assets/css/control.css">

<style>
  .table-responsive {
    overflow-x: auto;
  }
  .compare-list-properties th,
  .compare-list-properties td {
    min-width: 150px; /* ensure columns have min width on small screens */
    vertical-align: middle;
  }

  @media (max-width: 768px) {
    .compare-list-properties th, 
    .compare-list-properties td {
      text-align: center; /* better alignment on small screens */
      padding: 0.5rem;
    }
  }
</style>

</head>

<body class="compare-page">

    <div class="preloader">
        <div class="loader"></div>
    </div>

    <div id="page_wrapper" class="">
        <!--============== Header Section Start ==============-->
        <%- include("partials/navbar.ejs")%>
            <%- include("partials/lead-model.ejs")%>

                <!--================== Header Section End =================-->

                <!--============== Page Banner Section Start ==============-->
                <div class="full-row inner-page-banner py-5">
                    <div class=" container">
                    <div class="row">
                        <div class="col">
                            <div class="page-title-wrapper d-lg-flex flex-column gap-3">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb mb-0 bg-transparent p-0">
                                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">Compare</li>
                                    </ol>
                                </nav>
                                <h1 class="page-title pt-2">Compare</h1>
                            </div>
                        </div>
                    </div>
                </div>
    </div>
    <!--=============== Page Banner Section End ===============-->

    <!--================ Compare section Start ================-->
    <div class="full-row pt-0">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="table-responsive  ">
                 
                          <div class="table-responsive">
  <table class="table table-striped table-bordered compare-list-properties bg-light shadow-sm m-0 rounded-5">
    <tbody>
      <!-- Header Row: Property Images + Title + Price -->
      <tr class="bg-light">
        <th class="text-start  fw-bold text-start bg-light" style="color: black !important;">Images</th>
        <% data.property.forEach((prop) => { %>
          <th class="text-center align-top p-3">
            <div class="position-relative mb-3">
              <img src="<%= prop.imageUrl %>" class="img-fluid rounded" style="height:150px; width:auto;" alt="<%= prop.title %>">
              <button class="btn btn-sm btn-danger position-absolute top-0 end-0 remove-property" data-id="<%= prop.id %>">
                <i class="fas fa-times text-white"></i>
              </button>
            </div>
            <h5 class="color-secondary mb-1"><%= prop.title %></h5>
            <span class="text-primary fw-bold">
              <% if(prop.propertyStatus=="For Rent"){ %>
                ₹<%=prop.rent%><small> /Month</small>
              <% } %>
              <% if(prop.propertyStatus=="For Sale"){ %>
                ₹<%=prop.priceFromInWords%> - ₹<%=prop.priceToInWords%> <small>/All Inclusive</small>
              <% } %>
            </span>
          </th>
        <% }) %>
      </tr>

      <!-- Example Data Rows -->
      <tr>
        <td class="fw-bold text-start bg-light">Area</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.areaFrom%> Sqft</td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Rooms</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.additionalInformation.rooms%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Bathrooms</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.additionalInformation.bathrooms%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Property Stage</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.propertyStage%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Property Status</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.propertyStatus%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Property Type</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.propertyType%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Near By Place</td>
        <% data.property.forEach(prop=> { %>
          <td>
            <ul class="list-unstyled mb-0">
              <% prop.additionalInformation.nearByPlace.forEach(place => { %>
                <li>📍 <%= place.placeName %> - <%= place.distance %></li>
              <% }) %>
            </ul>
          </td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Year of Construction</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.yearOfConstruction%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Location</td>
        <% data.property.forEach(prop=> { %>
          <td><i class="fa-solid fa-location-dot"></i> <%=prop.location.locationName%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Builder Name</td>
        <% data.property.forEach(prop=> { %>
          <td><%=prop.builderName%></td>
        <% }) %>
      </tr>
      <tr>
        <td class="fw-bold text-start bg-light">Amenities</td>
        <% data.property.forEach(prop=> { %>
          <td>
            <% prop.amenities.forEach((amenity,i)=> { %>
               <%= amenity.name %><%= i < prop.amenities.length-1 ? ',' : '' %>
            <% }) %>
          </td>
        <% }) %>
      </tr>
    </tbody>
  </table>
</div>


                  

                    </div>
                </div>
            </div>
        </div>
    </div>







    <!--================= Compare section End =================-->
    <!--================= Footer Section Start ================-->
    <footer class="full-row bg-footer" style="padding-bottom: 30px">
        <div class="container">
            <div class="row row-cols-lg-4 row-cols-md-2 row-cols-1">
                <div class="col">
                    <div class="widget footer-widget widget-about">
                        <div class="footer-logo mb-4">
                            <a href="#"><img src="assets/images/logo/logo-full-white.png" alt="Image not found!" /></a>
                        </div>
                        <p>When it comes to the world of real estate, a good company stands out from the
                            rest by redefining excellence in every aspect of its operations.</p>
                    </div>
                    <div class="widget footer-widget social-widget">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-google-plus-g"></i></a>
                        <a href="#"><i class="fab fa-pinterest-p"></i></a>
                    </div>
                </div>
                <div class="col">
                    <div class="widget footer-widget contact-widget">
                        <h3 class="widget-title">Contact Info</h3>
                        <ul>
                            <li>Uniland Agency 301 The Greenhouse, Custard Factory, London, E3 8DY.</li>
                            <li><a href="callto:+1 246-345-0695">+1 246-345-0695</a></li>
                            <li>helpline@uniland.com</li>
                        </ul>
                    </div>
                </div>
                <div class="col">
                    <div class="widget footer-widget footer-nav">
                        <h3 class="widget-title">Quick Links</h3>
                        <ul>
                            <li><a href="#">Our Services</a></li>
                            <li><a href="#">Investment Solution</a></li>
                            <li><a href="#">Frequenly Ask Question</a></li>
                            <li><a href="#">How It Work</a></li>
                            <li><a href="#">Become a Member</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col">
                    <div class="widget footer-widget newslatter-widget">
                        <h4 class="widget-title">Appointment</h4>
                        <p>The process for scheduling appointments, whether it's through phone calls,
                            emails, online booking systems, or appointment-setting apps.</p>
                        <a href="#" class="btn btn-primary w-100">Register Now</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!--============== Footer Section End ==============-->

    <!--============== Copyright Section Start ==============-->
    <div class="copyright font-primary py-3">
        <div class="container">
            <div class="row row-cols-md-2 row-cols-1">
                <div class="col">
                    <p class="color-white mb-0">©2025 Uniland All right reserved</p>
                </div>
                <div class="col">
                    <ul class="bottom-footer-nav list-color-gray">
                        <li><a href="#">Privacy & Policy </a></li>
                        <li>|</li>
                        <li><a href="#">Site Map</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <!--================= Copyright Section End =================-->
    </div>

    <!-- Scroll to top -->
    <div class="scroll-top-vertical xs-mx-none" id="scroll">Back to top <i
            class="ms-2 fa-solid fa-arrow-right-long"></i></div>

    <!-- Javascript Files -->
    <script src="assets/js/jquery.min.js"></script>
    <script src="assets/js/bootstrap.min.js"></script>
    <script src="assets/js/fancybox.min.js"></script>
    <script src="assets/js/owl.carousel.min.js"></script>
    <script src="assets/js/wow.min.js"></script>
    <script src="assets/js/mixitup.min.js"></script>
    <script src="assets/js/range/tmpl.js"></script>
    <script src="assets/js/range/jquery.dependClass.js"></script>
    <script src="assets/js/range/draggable.js"></script>
    <script src="assets/js/range/jquery.slider.js"></script>
    <script src="assets/js/paraxify.js"></script>
    <script src="assets/js/custom.js"></script>
<script>
  window.properties = <%- JSON.stringify(data.property) %>;
</script>
<script src="assets/js/compare-property.js"></script>
</body>

</html>