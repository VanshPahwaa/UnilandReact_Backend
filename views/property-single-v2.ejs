                            <div class="entry-single-wrapper">
                                <div class="entry-single-thumbnail">
                                    <div id="single-property" style="width:1200px; height:1000px; margin:0 auto 30px;">
                                        <!-- Slide 1-->
                                        <div class="ls-slide" data-ls="duration:7500; transition2d:5; kenburnszoom:in; kenburnsscale:1.2;">   <img width="1920" style="height: 100%;" src="<%=data.property.imageUrl%>" class="ls-bg" alt="" /> </div>
                                        
                                        <%if(data.property && data.property.secondaryImageUrl){%>
                                            <%data.property.secondaryImageUrl.map((image,index)=>{%>
                                        <div class="ls-slide" data-ls="duration:7500; transition2d:5; kenburnszoom:out; kenburnsscale:1.2;"> <img width="1920" height="1080" src="<%=image%>" class="ls-bg" alt="" /> </div>
                                           <% })%>
                                            <%}%>
                                        <!-- Slide 2-->
                                        
                                        <!-- Slide 3-->
                                     
                                    </div>
                                </div>
                                <div class="entry-single-header">
                                    <div class="page-title-wrapper d-flex flex-column">
                                        <nav aria-label="breadcrumb">
                                            <ol class="breadcrumb mb-0 bg-transparent p-0">
                                                <li class="breadcrumb-item"><a href="/">Home</a></li>
                                                <li class="breadcrumb-item"><a href="/front-property">Property</a></li>
                                                <li class="breadcrumb-item active" aria-current="page"><%=data.property.title%></li>
                                            </ol>
                                        </nav>
                                        <h1 class="entry-single-title"><%=data.property.title%></h1>
                                        <span class="listing-location"><i class="fas fa-map-marker-alt"></i> <%=data.property.address.unit%>, <%=data.property.address.street%>, <%=data.property.address.city%>, <%=data.property.address.district%>, <%=data.property.address.state%>, <%=data.property.address.pincode%></span>
                                        <div class="type"><span class="rent text-white"><%=data.property.propertyStatus%></span></div>
                                    </div>
                                    <div class="entry-property-price-wrapper">
                                        <div class="flex-row d-flex">
                                           

                                            <ul class="d-flex flex-row g-3">
                                                <li>
                                                 <button data-bs-toggle="modal" data-bs-target="#interestedPropertyLeadModal" class="btn btn-primary btn-hover-secondary hover-flash-move me-2">Interested</button>
                                                </li>
                                                <li><div id="downloadPDF" onclick="window.location.href='/downloadPDF/<%=data.property._id%>'" class="btn btn-primary btn-hover-white"><i class="fa-solid fa-download"></i></div></li>
                                            </ul>
                                        </div>

                                        <% if (data.property.price){%>
                                            <span class="listing-price">₹<%=data.property.price%><small> / Fixed</small></span>
                                            <%}%>
                                        <% if (data.property.rent){%>
                                            <span class="listing-price">₹<%=data.property.rent%><small> / Monthly</small></span>
                                        <%}%>
                                    </div>
                                </div>
                                
                                <div class="entry-single-content-wrapper">
                                    <div class="row g-4">
                                        <div class="col-12">
                                            <div class="single-content-wrapper">
                                                <div class="single-property-overview">
                                                    <h4 class="text-uppercase ls-3 fw-semibold border-bottom fs-6 color-dark pb-2 mb-4">Overview</h4>
                                                    <ul class="property-info">
                                                        <li><span>Apartment:</span> <%=data.property.additionalInformation.rooms%> BHK</li>
                                                        <li><span>Bathrooms:</span> <%=data.property.additionalInformation.bathrooms%></li>
                                                        <li><span>Property Type:</span> <%=data.property.propertyType%></li>
                                                        <li><span>Area:</span> <%=data.property.areaFrom%>-<%=data.property.areaTo%> sq. ft.</li>
                                                        <li><span>Property Stage:</span> <%=data.property.propertyStage%></li>
                                                        <li><span>Builder Name:</span> <%=data.property.builderName%></li>
                                                        <li><span>Year of Construction:</span> <%=data.property.yearOfConstruction%></li>
                                                    </ul>
                                                </div>
                                                
                                                <div class="single-property-details">
                                                    <h4 class="text-uppercase ls-3 fw-semibold border-bottom fs-6 color-dark pb-2 mb-4">Address</h4>
                                                    <ul class="property-address">
                                                        <li><span>House/Unit No.:</span> <%=data.property.address.unit%></li>
                                                        <li><span>City :</span><%=data.property.address.city%></li>
                                                        <li><span>Zip/Postal Code :</span> <%=data.property.address.pincode%></li>
                                                        <li><span>Area :</span><%=data.property.address.street%></li>
                                                        <li><span>State/Province :</span> <%=data.property.address.state%></li>
                                                        <li><span>Country :</span>India</li>
                                                    </ul>
                                                </div>
                                                <div class="single-property-details">
                                                    <h4 class="text-uppercase ls-3 fw-semibold border-bottom fs-6 color-dark pb-2 mb-4">Property Features</h4>
                                                    <ul class="property-feature list-style">
                                                    
                                                       <% data.property.amenities.map((amenity,index)=>{%>
                                                        <li><%=amenity.name%></li>
                                                        <%})%>
                                                    </ul>
                                                </div>

