    <script>
        


const interestedPropertyLeadModal = document.getElementById("propertyLeadForm")

interestedPropertyLeadModal.addEventListener("submit", async function (e) {
    try {
        console.log("propertyLeadForm")
        e.preventDefault()
        const formData = new FormData(this);
        const urlEncodedData = new URLSearchParams(formData)
        const response = await fetch(this.action, {
            method: "post",
            body: urlEncodedData
        })
        const data = await response.json()
        if (data.success) {
            console.log("in toastify")
            Toastify({
                text: data.message,
                duration: 3000,
                gravity: "top",
                position: "center",
                close: true,
                backgroundColor: "#AA8453",
                style: {
                    color: "#FFFFFF",
                }
            }).showToast();
            this.reset()
        } else {
            Toastify({
                text: data.message,
                duration: 3000,
                gravity: "top",
                position: "center",
                close: true,
                backgroundColor: "#AA8453",
                style: {
                    color: "#FFFFFF"
                }
            }).showToast();
        }
    } catch (error) {
        Toastify({
            text: error.message,
            duration: 3000,
            gravity: "top",
            position: "center",
            close: true,
            backgroundColor: "#AA8453",
            style: {
                color: "#FFFFFF"
            }
        }).showToast();
    }
})


    </script>
    

