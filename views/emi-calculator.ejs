    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Uniland - Real Estate HTML5 Template">
    <meta name="keywords" content="real estate, property, property search, agent, apartments, booking, business, idx, housing, real estate agency, rental">
    <meta name="author" content="unicoder">
    <title>Uniland - Real Estate HTML5 Template</title>
    <!-- Favicon -->
    <link rel="shortcut icon" href="assets/images/favicon2.ico">

    <!-- Google Font -->    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

    <!--  CSS Style -->
    <link rel="stylesheet" href="assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="assets/css/all.min.css">
    <link rel="stylesheet" href="assets/css/animate.min.css">
    <link rel="stylesheet" href="assets/css/fancybox.min.css">
    <link rel="stylesheet" href="assets/css/layerslider.css">
    <link rel="stylesheet" href="assets/css/owl.carousel.min.css">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="stylesheet" href="assets/css/control.css">
     <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">


    <style>

         input[type=number]::-webkit-inner-spin-button,
            input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
            }

   input[name="mobileNumber"]{
            border:none;
            outline: none;
        }
        input[name="mobileNumber"]:hover{
            border:none;
            box-shadow: none;
            outline:none;
        }

#resultTable table {
    background-color: #ffffff22; /* semi-transparent background */
    border-radius: 10px;
    overflow: hidden;
    width: 100%;
    max-width: 500px;
    margin: 1rem auto;
    padding: 2rem;
    font-family: 'Segoe UI', sans-serif;
}

#resultTable th {
    background-color: #12171F; /* primary base color */
    color: #fff;
    text-align: center;
    font-weight: 600;
    padding: 0.8rem;
}

#resultTable td {
    background-color: #fff;
    color: black;
    text-align: center;
    padding: 0.7rem;
    font-weight: 500;
}

#resultTable tr:nth-child(even) td {
    background-color: #f5f5f5;
}

#resultTable td:first-child {
    font-weight: 600;
    color: black;
}

    </style>
</head>
<body class="blog-grid-page">

    <div class="preloader">
        <div class="loader"></div>
    </div>

    <div id="page_wrapper" class="bg-light-gray">
        <!--============== Header Section Start ==============-->
        <header class="main-header header-style-1 bg-white">
            <%-include("partials/navbar.ejs")%>
            <%-include("partials/lead-model.ejs")%>
        </header>
        <!--================== Header Section End =================-->

        <!--============== Page Banner Section Start ==============-->
        <div class="full-row inner-page-banner py-5">
            <div class="container">
                <div class="row">
                    <div class="col">
                        <div class="page-title-wrapper d-lg-flex flex-column gap-3">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-0 bg-transparent p-0">
                                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                                    <li class="breadcrumb-item active mb-2" aria-current="page">EMI Calculator</li>
                                </ol>
                            </nav>
                           
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--=============== Page Banner Section End ===============-->

        <!--================== Page Content Start =================-->
        <div class="full-row pt-0 px-4">
        <div class="container">
        <div class="row align-items-start justify-content-between">
            <div class="col-md-5 col-12 ">
                <h3 class=" mb-3">EMI CALCULATOR</h3>
              
                   <form id="emiForm" class="p-4  rounded shadow-sm" style="max-width: 400px; background-color: #12171F;">

  <!-- Principal Amount -->
  <div class="mb-4">
    <label for="principal" class="form-label fs-5 text-white fw-semibold">Principal Amount:</label>
    <div class="d-flex align-items-center border border-primary rounded px-2" style="height: 60px; background-color: #fff;">
      <span class="fs-5 me-2">₹</span>
      <input type="number" id="principal" name="principal" class="form-control border-0 p-0"
             value="1200000" required style="outline:none;border:none;">
    </div>
  </div>

  <!-- Interest Rate -->
  <div class="mb-4">
    <div class="d-flex flex-row justify-content-between">
        <label for="interestRate" class="form-label text-white fs-6 fw-medium">Annual Interest Rate (%):</label>
       <span class="d-flex align-items-center">
  <output for="rate" id="rateOutput" class="fs-2 fw-medium text-white ">6</output><span>%</span>
</span>

    </div>
    <input type="range" class="form-range w-100" min="0" max="15" value="6" id="interestRate" name="rate">
  </div>

  <!-- Time -->
  <div class="mb-4 ">
        <div class="d-flex flex-row justify-content-between">
            <label for="time" class="form-label fw-medium text-white ">Time (in years):</label>
       <span class="d-flex align-items-center">
           <output for="time" id="timeOutput" class="fs-1 fw-medium text-white " >8</output><span class="ms-1">years</span>
</span>
</div>
    <input type="range" class="form-range w-100" min="1" max="30" value="8" id="time" name="time">
  </div>

  <div class="d-flex flex-row gap-2">

  <!-- Submit Button -->
  <button type="reset" id="resetButton" class="btn btn-light w-100 fw-semibold " style="color: #313145; ">Reset Values</button>
  <button type="submit" id="calculateButton" class="btn btn-light w-100 fw-semibold " style="color: #313145; ">Calculate EMI</button>

</div>
</form>


              
                
            </div>
            <div class="col-12 col-md-5 d-flex flex-column text-center justify-content-center align-items-center g-3">
                <h3 class="color-primary text-center">Payment Breakdown</h3>
                <div class="h-100">
                    <canvas id="myChart"></canvas>
                </div>
                
                <div id="resultTable" class="mt-4">


                </div>
            </div>
    </div>
            </div>
        </div>
        <!--=================== Page Content End ==================-->

        <!--================= Footer Section Start ================-->
    <%- include("partials/footer.ejs")%>
        <!--================= Copyright Section End =================-->
    </div>

    <!-- Scroll to top -->
    <div class="scroll-top-vertical xs-mx-none" id="scroll">Back to top <i class="ms-2 fa-solid fa-arrow-right-long"></i></div>

    <!-- Javascript Files -->
    <script src="assets/js/jquery.min.js"></script>
    <script src="assets/js/bootstrap.min.js"></script>
    <script src="assets/js/fancybox.min.js"></script>
    <script src="assets/js/owl.carousel.min.js"></script>
    <script src="assets/js/wow.min.js"></script>
    <script src="assets/js/mixitup.min.js"></script>
    <script src="assets/js/range/tmpl.js"></script>
    <script src="assets/js/range/jquery.dependClass.js"></script>
    <script src="assets/js/range/draggable.js"></script>
    <script src="assets/js/range/jquery.slider.js"></script>
    <script src="assets/js/paraxify.js"></script>
    <script src="assets/js/custom.js"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <script>
        const ctx = document.getElementById('myChart');
        const interestRate = document.getElementById('interestRate');
        const interestRateOutput = document.getElementById('rateOutput');
        const principalAmount = document.getElementById("principal")
        const time = document.getElementById("time");
        const timeOutput = document.getElementById('timeOutput');



        // window.addEventListener("DOMContentLoaded",()=>{
        //     updateChart()
        // })
        // chart
        // const ctx = document.getElementById('myChart');
        const myChart = new Chart(ctx, {
            type: 'pie',
            data: {
                labels: ['Principal Amount', 'EMI'],
                datasets: [{
                    label: 'Total Repayment',
                    data: [1200000, 1513892.76],
                    backgroundColor: [
                        '#A0522D',
                        '#e3b985'
                                        ],
                    hoverOffset: 4
                }]
            },
        });


        // function calculateEMI() {
        //     let monthlyRate = interestRate.value / 1200;
        //     let totalMonth = time.value * 12
        //     console.log(monthlyRate, totalMonth)
        //     let EMI = (((totalMonth * 0.01) * (Math.pow((1 + monthlyRate), totalMonth))) / (Math.pow((1 + monthlyRate), totalMonth) - 1));
        //     console.log(EMI)
        // }

        function calculateEMI() {
            let P = principal.value; // Principal loan amount
            let r = interestRate.value / 1200; // Monthly interest rate
            let n = time.value * 12;   // Number of months

            let EMI = (P * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
            console.log("EMI:", EMI.toFixed(2));
            return n*EMI;
        }


        function updateChart() {
            let totalEMI= calculateEMI();
            myChart.data.datasets[0].data = [principalAmount.value,totalEMI ];
            myChart.update()
        }

    
        // document.getElementById("emiForm",function(e){
        //     e.preventDefault()
        //     updateChart()
        // })

        // Set initial value
        interestRate.addEventListener('input', function () {
            interestRateOutput.textContent = this.value;
            updateChart()
        });

        time.addEventListener('input', function () {
            timeOutput.textContent = this.value;
            updateChart()
        });

        // principalAmount
         principalAmount.addEventListener('input', function () {
            console.log("hlo")
            updateChart()
        });

        const resultDiv=document.getElementById("resultTable")
        document.getElementById("emiForm").addEventListener("submit",function(e){
            e.preventDefault()

            let emi=calculateEMI()
            let loanAmount=(principalAmount.value + (emi * time.value * 12))
            loanAmount=Number(loanAmount).toFixed(2)
            resultDiv.innerHTML = `
<table class="table table-bordered mt-3 shadow-sm">
    <thead>
        <tr>
            <th>Parameter</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Total EMI</td>
            <td>₹${emi.toFixed(2)}</td>
        </tr>
        <tr>
            <td>Total Loan Amount</td>
            <td>₹${loanAmount}</td>
        </tr>
        <tr>
            <td>Total Duration</td>
            <td>${time.value} years</td>
        </tr>
    </tbody>
</table>`


     updateChart()

});

        document.getElementById("resetButton").addEventListener("click",function(){

                time.value = 8; // default
    interestRate.value = 6; // default
    principalAmount.value = 1200000; // default

    // Trigger input events so listeners update outputs
    [time, interestRate, principalAmount].forEach(input => 
        input.dispatchEvent(new Event("input"))
    );
        })
      


    </script>

</body>
</html>